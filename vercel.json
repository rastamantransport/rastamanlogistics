{
  "buildCommand": "echo skip",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "cleanUrls": true,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/:path*/index.html", "destination": "/:path*", "permanent": true },
    { "source": "/:path*.html", "destination": "/:path*", "permanent": true }
  ]
}